# Desktop entry for the containerized PASCOM client. Install it to
# ~/.local/share/applications/ with Exec= rewritten to the absolute path of
# pascom-client.sh (the desktop session's PATH often does not include
# ~/.local/bin), see README.md ("Desktop integration").
#
# SPDX-FileCopyrightText: foundata GmbH <https://foundata.com>
# SPDX-License-Identifier: GPL-3.0-or-later

[Desktop Entry]
Type=Application
Name=PASCOM Client
Comment=PASCOM softphone client (running in an OCI container)
Exec=pascom-client.sh
Icon=pascom-client
Terminal=false
Categories=Network;Telephony;
StartupWMClass=net.pascom.pascom_Client
